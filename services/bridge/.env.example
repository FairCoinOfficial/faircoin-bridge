# FairCoin RPC
FAIR_NETWORK=testnet                  # testnet | mainnet
FAIR_RPC_URL=http://127.0.0.1:46375   # testnet default
FAIR_RPC_USER=
FAIR_RPC_PASSWORD=

# Base
BASE_NETWORK=mainnet                  # sepolia | mainnet
BASE_RPC_URL=                         # Alchemy primary
BASE_RPC_URL_FALLBACK=                # Infura fallback
# Deployed 2026-04-16 to Base mainnet. See contracts/deployments.json.
WFAIR_CONTRACT_ADDRESS=0xF2853CedDF47A05Fee0B4b24DFf2925d59737fb3
# Solo EOA launch — no Safe. SAFE_ADDRESS is the same EOA that holds admin/minter/pauser.
SAFE_ADDRESS=0xee8b8B9B7CFF6cDb51DA8f92a511005859007521
SAFE_TX_SERVICE_URL=https://safe-transaction-base.safe.global

# Bridge signer (Base-side gas payer, NOT mint key — mint is via Safe)
BRIDGE_EOA_PRIVATE_KEY=                # env-fallback only for dev; prod uses KMS

# FairCoin signer (withdrawal key)
FAIR_HOT_WALLET_XPRV=                  # hot wallet, 5% of TVL max
FAIR_BRIDGE_XPUB=                      # deposit HD xpub (watch-only)
FAIR_DEPOSIT_DERIVATION_PATH=m/44'/119'/0'/0

# Signing modes
# direct_eoa  = bridge EOA mints directly (requires MINTER_ROLE on WFAIR); fastest, fine while TVL cap is the backstop
# safe_proposal = worker proposes a Safe tx; 2nd signer + execution are manual via the Safe UI
MINT_AUTH_MODE=direct_eoa
# node_wallet = faircoind wallet signs releases via sendtoaddress (default)
# local_hd    = build + sign in-service from FAIR_HOT_WALLET_XPRV (phase 2, not yet implemented)
FAIR_HOT_WALLET_MODE=node_wallet

# Storage
MONGO_URI=mongodb://127.0.0.1:27017/faircoin-bridge
REDIS_URL=redis://127.0.0.1:6379

# Policy
MAX_TVL_FAIR=1000
MIN_DEPOSIT_FAIR=10
BRIDGE_FEE_BPS=30                      # 0.3%
FAIR_CONFIRMATIONS=6
BASE_CONFIRMATIONS=20
PER_ADDRESS_DAILY_CAP_FAIR=100

# Alerting
DISCORD_WEBHOOK_URL=

# Buy-FAIR flow
# One of the following must be set to enable the buy endpoints. The bridge
# derives m/44'/60'/0'/0/{index} as per-order payment addresses and holds the
# private keys so the orchestrator can sweep funds into the Uniswap router.
BUY_PAYMENT_HD_XPRV=
BUY_PAYMENT_HD_MNEMONIC=

# Base mainnet defaults (override on testnets only)
USDC_BASE_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
WFAIR_USDC_POOL_ADDRESS=0x9F4F694390c60b51e30461c785C1345A1545b7ca
UNISWAP_V3_QUOTER=0x3d4e44Eb1374240CE5F1B871ab261CD16335B76a
UNISWAP_V3_SWAP_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481

BUY_SLIPPAGE_BUFFER_BPS=200
BUY_BRIDGE_FEE_BPS=100
BUY_MIN_FAIR=1
BUY_MAX_FAIR=1000
BUY_QUOTE_TTL_SECONDS=900

# Optional card-payment providers (leave blank until business KYC complete)
MOONPAY_API_KEY=
TRANSAK_API_KEY=

# Buy-back / treasury distribution
# Periodic worker that drains accumulated USDC fees from the bridge admin EOA
# into WFAIR via Uniswap, then bridgeBurns the proceeds split across three
# FAIR destinations: a provably-unspendable burn address, a community
# treasury, and a masternode reward pool consumed by the masternode booster
# (task #29). DISABLED BY DEFAULT — operator must wire all three FAIR
# destinations and flip BUYBACK_ENABLED=true.
BUYBACK_ENABLED=false
BUYBACK_THRESHOLD_USDC=100              # USDC (whole units) before triggering
BUYBACK_INTERVAL_MS=3600000             # 1 hour
BUYBACK_BURN_BPS=5000                   # 50% to burn address (deflationary)
BUYBACK_TREASURY_BPS=3000               # 30% to community treasury
BUYBACK_MASTERNODE_BPS=2000             # 20% to masternode reward pool
# The three BPS values MUST sum to exactly 10000.
# FAIR address (mainnet, version byte 35) with provably-unknown private key.
# Default below is the canonical "F1111111…" derived from the all-zero hash160
# — see src/lib/burn-address.ts for derivation. Override only if a more
# socially-recognised burn address is preferred.
FAIR_BURN_ADDRESS=
# Community treasury FAIR address (governance / dev fund). Hot wallet under
# operator/community control. Required when BUYBACK_ENABLED=true.
FAIR_TREASURY_ADDRESS=
# Separate FAIR hot wallet that the masternode reward booster (task #29)
# consumes from. Required when BUYBACK_ENABLED=true.
FAIR_MASTERNODE_REWARD_ADDRESS=

# Masternode reward booster (task #29)
# Companion to the buy-back worker. Periodically reads the FAIR balance at
# FAIR_MASTERNODE_REWARD_ADDRESS (funded by the buy-back worker's 20% slice)
# and distributes it pro-rata across all ENABLED FairCoin masternodes via
# sendtoaddress — boosting operator yield and incentivising more masternodes
# (more collateral locked, more decentralisation, less circulating supply).
# DISABLED BY DEFAULT: enable only after (a) the buy-back worker has been
# funding the pool address for some time, and (b) operators have been notified
# that payouts are starting. The bridge daemon must hold the privkey for
# FAIR_MASTERNODE_REWARD_ADDRESS (same importprivkey ceremony as the hot
# wallet) so sendtoaddress can draw from its received balance.
MASTERNODE_REWARDS_ENABLED=false
MASTERNODE_REWARDS_INTERVAL_MS=604800000   # weekly
MASTERNODE_REWARDS_MIN_BALANCE_FAIR=10     # skip cycle if pool < 10 FAIR
MASTERNODE_REWARDS_PAYOUT_FEE_FAIR=0.001   # FairCoin tx fee buffer per payout

# Admin API
# Bearer token guarding the admin endpoints (e.g. manual buyback trigger,
# cycle status). Leave blank to disable the admin router.
ADMIN_API_TOKEN=

# API
PORT=3100
API_CORS_ORIGIN=
